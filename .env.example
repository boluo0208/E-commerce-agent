APP_NAME=E-commerce Product Content Agent
APP_ENV=development

# DeepSeek OpenAI-compatible API settings.
# Fill this when you are ready to call DeepSeek for real content generation.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Mimo vision model settings.
# Configure these when the image-understanding endpoint is confirmed.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=
MIMO_MODEL=

# Keep true during early development so the pipeline works without an API key.
MOCK_LLM_WHEN_NO_KEY=true
MOCK_VISION_WHEN_NO_KEY=true

# Number of product images processed concurrently.
MAX_CONCURRENT_IMAGES=4

# Split side-by-side composite product images before vision analysis.
AUTO_SPLIT_COMPOSITE_IMAGES=true

# Translate visible Chinese text on product images into English.
TRANSLATE_IMAGE_TEXT=true
TRANSLATE_IMAGE_TEXT_MIN_CONFIDENCE=0.55
